# Daraja / M-Pesa SDK — Environment Variables
# Copy this to .env and fill in your values from the Daraja developer portal.

# ── Core credentials (required) ────────────────────────────────────────────────
MPESA_CONSUMER_KEY=your_consumer_key_here
MPESA_CONSUMER_SECRET=your_consumer_secret_here
MPESA_SHORTCODE=174379
MPESA_PASSKEY=bfb279f9aa9bdbcf158e97dd71a467cd2e0c893059b10f78e6b72ada1ed2c919

# ── Environment ─────────────────────────────────────────────────────────────────
# sandbox | production
MPESA_ENVIRONMENT=sandbox

# ── Callback URLs (must be publicly reachable HTTPS) ────────────────────────────
# STK Push callback
MPESA_CALLBACK_URL=https://yourapp.co.ke/mpesa/callback

# B2C / B2B / Reversal / Balance async result endpoints
MPESA_RESULT_URL=https://yourapp.co.ke/mpesa/result
MPESA_TIMEOUT_URL=https://yourapp.co.ke/mpesa/timeout

# ── Operator credentials (required for B2C, B2B, Reversal, Account Balance) ────
# Initiator name from the Daraja portal (API operator username)
MPESA_INITIATOR_NAME=testapi

# SecurityCredential: initiator password encrypted with Safaricom's public cert.
# Generate with: $client->...->generateSecurityCredential($password, $certPath)
# Or paste the pre-generated Base64 string here.
MPESA_SECURITY_CREDENTIAL=your_encrypted_security_credential_here
